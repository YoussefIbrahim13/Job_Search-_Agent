# ┌─────────────────────────────────────────────────────────┐
# │   Recruitment AI Agent — Environment Variables          │
# └─────────────────────────────────────────────────────────┘

# ── REQUIRED ────────────────────────────────────────────────────────────────

TAVILY_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# ── AI MODEL ────────────────────────────────────────────────────────────────

GROQ_MODEL=qwen/qwen3-32b
# ── OPTIONAL OVERRIDES ───────────────────────────────────────────────────────

TAVILY_MAX_RESULTS=5

MAX_AGENT_ITERATIONS=2

LOG_LEVEL=INFO